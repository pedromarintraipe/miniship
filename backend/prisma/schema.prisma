generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  VOCAL
  MUSICIAN
  ADMIN
}

model User {
  id          String        @id @default(uuid())
  name        String
  email       String        @unique
  password    String
  role        Role          @default(VOCAL)
  fontSize    Int           @default(16)
  showChords  Boolean       @default(true)
  createdAt   DateTime      @default(now())
  SongVariant SongVariant[]
}

model Song {
  id           String         @id @default(uuid())
  title        String
  artist       String?
  originalKey  String
  structure    Json           // Stores sections, lines, lyrics, and chords
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  SetlistSong  SetlistSong[]
  SongVariant  SongVariant[]
}

model Setlist {
  id          String        @id @default(uuid())
  name        String
  description String?
  date        DateTime?
  createdAt   DateTime      @default(now())
  SetlistSong SetlistSong[]
}

model SetlistSong {
  id          String   @id @default(uuid())
  setlist     Setlist  @relation(fields: [setlistId], references: [id], onDelete: Cascade)
  setlistId   String
  song        Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  songId      String
  variant     SongVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  variantId   String?
  position    Int
  selectedKey String
  notes       String?
  createdAt   DateTime @default(now())
}

model SongVariant {
  id          String   @id @default(uuid())
  song        Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
  songId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  name        String
  structure   Json
  isPublic    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  SetlistSong SetlistSong[]
}
